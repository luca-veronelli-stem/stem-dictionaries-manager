<Window x:Class="GUI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI.Windows"
        xmlns:views="clr-namespace:GUI.Windows.Views"
        xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DictionaryListViewModel}">
            <views:DictionaryListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DictionaryEditViewModel}">
            <views:DictionaryEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VariableListViewModel}">
            <views:VariableListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VariableEditViewModel}">
            <views:VariableEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandListViewModel}">
            <views:CommandListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandEditViewModel}">
            <views:CommandEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BoardListViewModel}">
            <views:BoardListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BoardEditViewModel}">
            <views:BoardEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserListViewModel}">
            <views:UserListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar (visibile solo se loggato) -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR (visibile solo se loggato) ========== -->
        <Border Grid.Column="0" Background="#2D2D30" Width="200"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,20,0,0">
                    <!-- Logo -->
                    <TextBlock Text="STEM Dictionaries"
                               Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Manager"
                               Foreground="#888888" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,2,0,10"/>

                    <!-- Utente corrente -->
                    <TextBlock Text="{Binding CurrentUserDisplayName}"
                               Foreground="#007ACC" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Navigazione principale -->
                    <Button Content="📚  Dizionari"
                            Command="{Binding NavigateToDictionariesCommand}"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="⚡  Comandi"
                            Command="{Binding NavigateToCommandsCommand}"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="📋  Schede"
                            Command="{Binding NavigateToBoardsCommand}"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="👥  Utenti"
                            Command="{Binding NavigateToUsersCommand}"
                            Style="{StaticResource SidebarButtonStyle}"/>

                    <Separator Margin="10,20,10,10" Background="#3E3E42"/>

                    <Button Content="⚙️  Impostazioni"
                            Command="{Binding NavigateToSettingsCommand}"
                            Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>

                <!-- Logout in basso -->
                <Button Grid.Row="1"
                        Content="🚪  Logout"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0,0,0,20"/>
            </Grid>
        </Border>

        <!-- ========== AREA CONTENUTO ========== -->
        <Grid Grid.Column="1" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header (visibile solo se loggato) -->
            <Border Grid.Row="0" Background="#3C3C3C" Height="50"
                    Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="20,0">
                    <TextBlock Text="{Binding PageTitle}"
                               Foreground="White" FontSize="20"
                               VerticalAlignment="Center"/>
                    <!-- Indietro a destra -->
                    <Button Command="{Binding GoBackCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="0" Content="← Indietro"/>
                </Grid>
            </Border>

            <!-- Contenuto -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="20"/>
        </Grid>
    </Grid>
</Window>
