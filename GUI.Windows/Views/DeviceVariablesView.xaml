<UserControl x:Class="GUI.Windows.Views.DeviceVariablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Intestazione -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Variabili standard:" FontSize="14" Foreground="#999999" 
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="SemiBold" 
                       Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1" Text="Caricamento..." FontSize="14" Foreground="#999999" Margin="0,0,0,10"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Error message -->
        <Border Grid.Row="2" Background="#F44336" Padding="10" Margin="0,0,0,10" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- DataGrid variabili standard -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Variables}"
                  Style="{StaticResource DarkDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}"
                  CellStyle="{StaticResource DarkDataGridCellStyle}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="200"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Indirizzo" Binding="{Binding FullAddress}" Width="100" MinWidth="80"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="2*" MinWidth="200"
                                    IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Attivo" 
                                         Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" MinWidth="60">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox" BasedOn="{StaticResource DarkDataGridCheckBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGloballyDisabled}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                    <DataGridCheckBoxColumn.EditingElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGloballyDisabled}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridCheckBoxColumn.EditingElementStyle>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toolbar salvataggio -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Salva" Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="120" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
