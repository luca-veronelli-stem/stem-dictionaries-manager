<UserControl x:Class="GUI.Windows.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}">

    <Grid Background="#1E1E1E">
        <!-- Card centrata -->
        <Border Background="#2D2D30" 
                CornerRadius="10"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="380">
            <StackPanel>
                <!-- Logo/Titolo -->
                <TextBlock Text="📚" 
                           FontSize="48"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBlock Text="STEM Dictionaries Manager" 
                           Foreground="White" 
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5" />

                <TextBlock Text="Gestione dizionari dispositivi STEM" 
                           Foreground="#888888" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30" />

                <!-- Errore -->
                <Border Background="#E40032" 
                        CornerRadius="4" 
                        Padding="10" 
                        Margin="0,0,0,15"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="White" 
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Label -->
                <TextBlock Text="Seleziona il tuo utente:" 
                           Foreground="#CCCCCC" 
                           FontSize="14"
                           Margin="0,0,0,10" />

                <!-- ComboBox utenti -->
                <ComboBox ItemsSource="{Binding AvailableUsers}"
                          SelectedItem="{Binding SelectedUser}"
                          DisplayMemberPath="DisplayName"
                          FontSize="14"
                          Padding="10"
                          Margin="0,0,0,20"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>

                <!-- Loading -->
                <TextBlock Text="Caricamento utenti..." 
                           Foreground="#888888" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                           Margin="0,0,0,10" />

                <!-- Pulsante accedi -->
                <Button Content="ACCEDI"
                        Command="{Binding ConfirmLoginCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
