<UserControl x:Class="GUI.Windows.Views.VariableEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VariableEditViewModel}"
             Loaded="UserControl_Loaded">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding FormTitle}" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Compila i campi per creare o modificare una variabile." Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Left" Width="600">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nome -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome *" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Padding="8,6" Margin="0,0,0,12"/>

                                <!-- Indirizzo -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Indirizzo *" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="High: 0x" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding AddressHighHex, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource HexAddressTextBoxStyle}" Margin="0,0,16,0"
                             PreviewTextInput="HexTextBox_PreviewTextInput"/>
                    <TextBlock Text="Low: 0x" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding AddressLowHex, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource HexAddressTextBoxStyle}" Margin="0,0,16,0"
                             PreviewTextInput="HexTextBox_PreviewTextInput"/>
                    <TextBlock Text="{Binding FullAddressDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Tipo Dato -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tipo Dato *" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox ItemsSource="{Binding DataTypeKinds}" SelectedItem="{Binding SelectedDataTypeKind}" 
                              Width="130" Padding="8,6" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding CustomDataType, UpdateSourceTrigger=PropertyChanged}" 
                             Width="150" Padding="8,6" 
                             IsEnabled="{Binding IsDataTypeOther}"
                             ToolTip="Tipo custom (es: MyStruct, CustomType[10])">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDataTypeOther}" Value="False">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <!-- Parametro Tipo (solo per Bitmapped, Array, String) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding DataTypeParamLabel}" VerticalAlignment="Center" Margin="0,0,0,12"
                           Visibility="{Binding RequiresDataTypeParam, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DataTypeParam, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}}" 
                         Width="100" HorizontalAlignment="Left" Padding="8,6" Margin="0,0,0,12"
                         Visibility="{Binding RequiresDataTypeParam, Converter={StaticResource BoolToVisibilityConverter}}"
                         PreviewTextInput="IntTextBox_PreviewTextInput" ToolTip="Dimensione o numero di word"/>

                <!-- Modalita Accesso -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Accesso" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding AccessModes}" SelectedItem="{Binding SelectedAccessMode}" 
                          Width="150" HorizontalAlignment="Left" Padding="8,6" Margin="0,0,0,12"/>

                <!-- Min/Max/Unita -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Min - Max / Unità" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}" Width="80" Padding="8,6" Margin="0,0,8,0" ToolTip="Valore minimo" PreviewTextInput="DoubleTextBox_PreviewTextInput"/>
                        <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}" Width="80" Padding="8,6" Margin="0,0,16,0" ToolTip="Valore massimo" PreviewTextInput="DoubleTextBox_PreviewTextInput"/>
                        <TextBox Text="{Binding Unit}" Width="80" Padding="8,6" ToolTip="Unità (es: °C, mm, kg)"/>
                    </StackPanel>
                    <TextBlock Text="Errore: Min deve essere minore o uguale a Max" Foreground="Red" FontSize="11" Margin="0,4,0,0"
                               Visibility="{Binding IsMinMaxValid, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                </StackPanel>

                <!-- Formato -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Formato" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Format}" Width="150" HorizontalAlignment="Left" Padding="8,6" Margin="0,0,0,12" ToolTip="Es: %.2f, %d"/>

                <!-- Descrizione -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Descrizione" VerticalAlignment="Top" Margin="0,8,0,12"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" Height="80" Padding="8,6" Margin="0,0,0,12"/>

                <!-- Abilitata -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Stato" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding IsEnabled}" Content="Variabile attiva" Margin="0,0,0,12"/>
            </Grid>
        </ScrollViewer>

        <!-- Error message -->
        <Border Grid.Row="2" Background="#FFEEEE" BorderBrush="#FF6666" BorderThickness="1" Padding="8" Margin="0,0,0,16" 
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC0000" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Command="{Binding CancelCommand}" Padding="16,8" Margin="0,0,8,0" MinWidth="100"/>
            <Button Content="Salva" Command="{Binding SaveCommand}" Padding="16,8" MinWidth="100" FontWeight="SemiBold" Background="#0078D4" Foreground="White"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                <TextBlock Text="Caricamento..." Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
