<Window x:Class="GUI.Windows.Views.UserSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stem Dictionaries Manager"
        Height="280" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#1E1E1E">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titolo -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="Stem Dictionaries Manager"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#007ACC"/>
            <TextBlock Text="Gestione dizionari dispositivi STEM"
                       FontSize="12" Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Label -->
        <TextBlock Grid.Row="2" Text="Seleziona utente:" 
                   FontSize="14" Foreground="White"/>

        <!-- ComboBox -->
        <ComboBox Grid.Row="4" x:Name="UserComboBox"
                  FontSize="14" Height="32"
                  DisplayMemberPath="DisplayName"
                  SelectionChanged="UserComboBox_SelectionChanged"/>

        <!-- Bottone -->
        <Button Grid.Row="6" x:Name="ConfirmButton"
                Content="Accedi" FontSize="14"
                Height="36" Width="120"
                HorizontalAlignment="Center"
                IsEnabled="False" IsDefault="True"
                Click="ConfirmButton_Click"
                Style="{StaticResource AccentButtonStyle}"/>
    </Grid>
</Window>
