<Window x:Class="GUI.Windows.Views.UserSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stem Dictionaries Manager"
        Height="280" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Titolo -->
            <RowDefinition Height="16"/>    <!-- Spaziatura -->
            <RowDefinition Height="Auto"/>  <!-- Label -->
            <RowDefinition Height="8"/>     <!-- Spaziatura -->
            <RowDefinition Height="Auto"/>  <!-- ComboBox -->
            <RowDefinition Height="*"/>     <!-- Spaziatura flessibile -->
            <RowDefinition Height="Auto"/>  <!-- Bottone -->
        </Grid.RowDefinitions>

        <!-- Titolo applicazione -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="Stem Dictionaries Manager"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#2D5F8A"/>
            <TextBlock Text="Gestione dizionari dispositivi STEM"
                       FontSize="12" Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Label selezione -->
        <TextBlock Grid.Row="2" 
                   Text="Seleziona utente:" 
                   FontSize="14"
                   Margin="0,0,0,0"/>

        <!-- ComboBox utenti -->
        <ComboBox Grid.Row="4"
                  x:Name="UserComboBox"
                  FontSize="14"
                  Height="32"
                  DisplayMemberPath="DisplayName"
                  SelectionChanged="UserComboBox_SelectionChanged"/>

        <!-- Bottone conferma -->
        <Button Grid.Row="6"
                x:Name="ConfirmButton"
                Content="Accedi"
                FontSize="14"
                Height="36" Width="120"
                HorizontalAlignment="Center"
                IsEnabled="False"
                IsDefault="True"
                Click="ConfirmButton_Click"/>
    </Grid>
</Window>
