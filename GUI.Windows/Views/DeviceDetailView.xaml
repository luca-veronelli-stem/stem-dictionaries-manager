<UserControl x:Class="GUI.Windows.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Intestazione dispositivo -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Dispositivo:" FontSize="14" Foreground="#999999" 
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="SemiBold" 
                       Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1" Text="Caricamento..." FontSize="14" Foreground="#999999" Margin="0,0,0,10"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Error message -->
        <Border Grid.Row="2" Background="#F44336" Padding="10" Margin="0,0,0,10" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- Lista dizionari -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Dictionaries}" 
                  SelectedItem="{Binding SelectedDictionary}"
                  Style="{StaticResource DarkDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}"
                  CellStyle="{StaticResource DarkDataGridCellStyle}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenDictionaryCommand}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Dizionario" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Semantic}" Width="120" MinWidth="80"/>
                <DataGridTextColumn Header="Variabili" Binding="{Binding VariableCount}" Width="100" MinWidth="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
