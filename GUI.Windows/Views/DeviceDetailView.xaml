<UserControl x:Class="GUI.Windows.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Intestazione dispositivo -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Dispositivo:" FontSize="14" Foreground="#999999" 
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="SemiBold" 
                       Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1" Text="Caricamento..." FontSize="14" Foreground="#999999" Margin="0,0,0,10"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Error message -->
        <Border Grid.Row="2" Background="#E40032" Padding="10" Margin="0,0,0,10" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- ── DIZIONARI ── -->
        <DockPanel Grid.Row="3">
            <TextBlock DockPanel.Dock="Top" Text="Dizionari" FontSize="13" FontWeight="SemiBold"
                       Foreground="White" Margin="0,0,0,8"/>
            <DataGrid ItemsSource="{Binding Dictionaries}" 
                      SelectedItem="{Binding SelectedDictionary}"
                      Style="{StaticResource DarkDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                      CellStyle="{StaticResource DarkDataGridCellStyle}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenDictionaryCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dizionario" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Semantic}" Width="120" MinWidth="80"/>
                    <DataGridTextColumn Header="Variabili" Binding="{Binding VariableCount}" Width="100" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ── SCHEDE ── -->
        <DockPanel Grid.Row="4" Margin="0,15,0,0">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Schede" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="➕ Nuova" Command="{Binding AddBoardCommand}" 
                        Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Right"/>
            </DockPanel>
        </DockPanel>

        <DataGrid Grid.Row="5" ItemsSource="{Binding Boards}" 
                  SelectedItem="{Binding SelectedBoard}"
                  Style="{StaticResource DarkDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}"
                  CellStyle="{StaticResource DarkDataGridCellStyle}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" 
                              Command="{Binding EditBoardCommand}" 
                              CommandParameter="{Binding SelectedBoard}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="180" MinWidth="100"/>
                <DataGridTextColumn Header="FW Type" Binding="{Binding FirmwareType}" Width="70" MinWidth="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="N°" Binding="{Binding BoardNumber}" Width="50" MinWidth="40">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Header="Primaria" Binding="{Binding IsPrimary}" Width="70" MinWidth="50" 
                                        IsReadOnly="True" ElementStyle="{StaticResource DarkDataGridCheckBoxStyle}"/>
                <DataGridTextColumn Header="Dizionario" Binding="{Binding DictionaryName}" Width="150" MinWidth="80"/>
                <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="120" MinWidth="80"/>
                <DataGridTextColumn Header="Indirizzo" Binding="{Binding ProtocolAddress}" Width="110" MinWidth="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
