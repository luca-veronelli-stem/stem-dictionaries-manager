<UserControl x:Class="GUI.Windows.Views.CommandEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommandEditViewModel}"
             Loaded="UserControl_Loaded"
             Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Compila i campi per creare o modificare un comando." 
                   Foreground="#888888" FontSize="13" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Left" Width="550">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nome -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource WatermarkTextBoxStyle}" Tag="Nome comando" MaxLength="100" Margin="0,0,0,12"/>

                <!-- Codice -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Codice" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="High: 0x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding CodeHighHex, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource HexAddressTextBoxStyle}" Margin="0,0,16,0"/>
                    <TextBlock Text="Low: 0x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding CodeLowHex, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource HexAddressTextBoxStyle}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding FullCodeDisplay}" Foreground="#007ACC" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Tipo -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tipo" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsResponse}" 
                          Content="È una risposta (response)" Foreground="White" Margin="0,0,0,12"/>

                <!-- Parametri -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Parametri" Foreground="White" VerticalAlignment="Top" Margin="0,8,0,12"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding ParametersText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Un parametro per riga"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="120"/>
                    <TextBlock Text="Un parametro per riga" Foreground="#888888" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Errore -->
        <Border Grid.Row="2" Background="#F44336" Padding="10" Margin="0,0,0,16" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- Bottoni -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Command="{Binding CancelCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"/>
            <Button Content="💾 Salva" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"
                    Background="#007ACC" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
