<UserControl x:Class="GUI.Windows.Views.CommandEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommandEditViewModel}"
             Loaded="UserControl_Loaded">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding FormTitle}" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Compila i campi per creare o modificare un comando." 
                       Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Left" Width="550">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nome -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome *" 
                           VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         MaxLength="100" Padding="8,6" Margin="0,0,0,12"/>

                <!-- Codice -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Codice" 
                           VerticalAlignment="Center" Margin="0,0,0,12"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="High: 0x" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding CodeHigh, StringFormat=X2}" 
                             Width="50" Padding="8,6" Margin="0,0,16,0"/>
                    <TextBlock Text="Low: 0x" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding CodeLow, StringFormat=X2}" 
                             Width="50" Padding="8,6" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding FullCodeDisplay}" 
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Tipo (Request/Response) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tipo" 
                           VerticalAlignment="Center" Margin="0,0,0,12"/>
                <CheckBox Grid.Row="2" Grid.Column="1" 
                          IsChecked="{Binding IsResponse}" 
                          Content="È una risposta (response)"
                          Margin="0,0,0,12"/>

                <!-- Parametri -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Parametri" 
                           VerticalAlignment="Top" Margin="0,8,0,12"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding ParametersText, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             Height="120"
                             Padding="8,6"/>
                    <TextBlock Text="Un parametro per riga" 
                               Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Error message -->
        <Border Grid.Row="2" 
                Background="#FFEEEE" 
                BorderBrush="#FF6666" 
                BorderThickness="1" 
                Padding="8" 
                Margin="0,0,0,16"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC0000" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" 
                    Command="{Binding CancelCommand}" 
                    Padding="16,8" Margin="0,0,8,0" MinWidth="100"/>
            <Button Content="Salva" 
                    Command="{Binding SaveCommand}" 
                    Padding="16,8" MinWidth="100" 
                    FontWeight="SemiBold" 
                    Background="#0078D4" Foreground="White"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" 
                Background="#80FFFFFF" 
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                <TextBlock Text="Caricamento..." Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
