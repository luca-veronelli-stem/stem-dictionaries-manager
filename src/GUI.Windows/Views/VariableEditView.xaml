<UserControl x:Class="GUI.Windows.Views.VariableEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VariableEditViewModel}"
             Loaded="UserControl_Loaded"
             Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Compila i campi per creare o modificare una variabile." 
                       Foreground="#888888" FontSize="13"
                       Visibility="{Binding IsNotDictionaryContext, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="Override per dizionario: puoi modificare stato, descrizione e interpretazioni bit. Gli altri campi sono in sola lettura." 
                       Foreground="#FFC04A" FontSize="13"
                       Visibility="{Binding IsDictionaryContext, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,16,0">
                <!-- Campi form a larghezza fissa -->
                <Grid HorizontalAlignment="Left" Width="750" IsEnabled="{Binding IsNotDictionaryContext}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nome -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Nome variabile" MaxLength="100" Margin="0,0,0,12"
                             BorderBrush="{Binding IsNameInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>

                    <!-- Indirizzo -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Indirizzo *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="High: 0x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AddressHighHex}" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock Text="Low: 0x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding AddressLowHex, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource HexAddressTextBoxStyle}" Margin="4,0,16,0"
                                 PreviewTextInput="HexTextBox_PreviewTextInput"
                                 BorderBrush="{Binding IsAddressLowInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>
                        <TextBlock Text="{Binding FullAddressDisplay}" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Tipo Dato -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tipo Dato *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <ComboBox ItemsSource="{Binding DataTypeKinds}" SelectedItem="{Binding SelectedDataTypeKind}" 
                                  Width="130" Padding="8,6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding CustomDataType, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource WatermarkTextBoxStyle}" Tag="Tipo custom"
                                 Width="150" Visibility="{Binding IsDataTypeOther, Converter={StaticResource BoolToVisibilityConverter}}"
                                 BorderBrush="{Binding IsCustomDataTypeInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>
                    </StackPanel>

                    <!-- Parametro Tipo -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding DataTypeParamLabel}" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"
                               Visibility="{Binding RequiresDataTypeParam, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DataTypeParam, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}}" 
                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Dimensione"
                             Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"
                             Visibility="{Binding RequiresDataTypeParam, Converter={StaticResource BoolToVisibilityConverter}}"
                             PreviewTextInput="IntTextBox_PreviewTextInput"
                             BorderBrush="{Binding IsDataTypeParamInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>
                </Grid>

                <!-- Word Size selector (solo per Bitmapped) -->
                <Grid HorizontalAlignment="Left" Width="750" IsEnabled="{Binding IsNotDictionaryContext}"
                      Visibility="{Binding IsBitmapped, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Word Size (bits) *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding WordSizeOptions}" 
                              SelectedItem="{Binding SelectedWordSize}"
                              Width="100" HorizontalAlignment="Left" Padding="8,6" Margin="0,0,0,12"/>
                </Grid>

                <!-- Sezione BitInterpretations (solo per Bitmapped con WordSize selezionato) - larghezza piena -->
                <StackPanel Visibility="{Binding HasWordSize, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,12">
                    <ItemsControl ItemsSource="{Binding WordGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="WordGroupBorder" Margin="0,0,0,16"
                                       Padding="4" Background="Transparent">
                                    <StackPanel>
                                        <!-- Header: Toggle a sinistra, Remove a destra -->
                                        <DockPanel Margin="0,0,0,6">
                                            <ToggleButton IsChecked="{Binding IsExpanded}" DockPanel.Dock="Left" Cursor="Hand">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <StackPanel Orientation="Horizontal" Background="Transparent">
                                                            <TextBlock x:Name="Arrow" Text="▾" Foreground="#888888" FontSize="13"
                                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="SemiBold" FontSize="13"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="Arrow" Property="Text" Value="▸"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <Button Content="🗑️" ToolTip="Rimuovi Word"
                                                    Command="{Binding DataContext.RemoveWordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                                        <Setter Property="Visibility" Value="Hidden"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                                                    <Condition Binding="{Binding DataContext.CanRemoveWord, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                                                                    <Condition Binding="{Binding DataContext.CanRemoveWord, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DockPanel>
                                        <!-- Contenuto collapsabile -->
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                                                      IsReadOnly="False"
                                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                                                      Style="{StaticResource DarkDataGridStyle}"
                                                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                                                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                                                      CellStyle="{StaticResource DarkDataGridCellStyle}"
                                                      MinHeight="38" MaxHeight="500"
                                                      HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Bit Index" Binding="{Binding BitIndex}" 
                                                                        IsReadOnly="True" Width="80" MinWidth="60"/>
                                                    <DataGridTextColumn Header="Meaning" Binding="{Binding Meaning, UpdateSourceTrigger=PropertyChanged}" 
                                                                        Width="*" MinWidth="200"
                                                                        EditingElementStyle="{StaticResource DarkDataGridTextBoxStyle}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <DockPanel Margin="0,6,0,0">
                                                <Button Content="+ Aggiungi Bit" 
                                                        Command="{Binding DataContext.AddBitToWordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ToolbarButtonStyle}"
                                                        DockPanel.Dock="Left"
                                                        Visibility="{Binding CanAddBit, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Button Content="🗑️ Elimina Bit"
                                                        Command="{Binding DataContext.RemoveLastBitFromWordCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ToolbarButtonStyle}"
                                                        DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                        Visibility="{Binding CanRemoveBit, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="➕ Aggiungi Word" Command="{Binding AddWordCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Campi rimanenti a larghezza fissa (read-only in DictionaryContext) -->
                <Grid HorizontalAlignment="Left" Width="750" IsEnabled="{Binding IsNotDictionaryContext}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                            <!-- Accesso -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Accesso" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AccessModes}" SelectedItem="{Binding SelectedAccessMode}" 
                                      Width="150" HorizontalAlignment="Left" Padding="8,6" Margin="0,0,0,12"/>

                            <!-- Min/Max/Unita -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Min - Max / Unità" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}" 
                                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Min" Width="80" Margin="0,0,8,0" PreviewTextInput="DoubleTextBox_PreviewTextInput"/>
                                    <TextBlock Text="—" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}" 
                                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Max" Width="80" Margin="0,0,16,0" PreviewTextInput="DoubleTextBox_PreviewTextInput"/>
                                    <TextBox Text="{Binding Unit}" Style="{StaticResource WatermarkTextBoxStyle}" Tag="Unità" Width="80"/>
                                </StackPanel>
                                <TextBlock Text="Errore: Min deve essere minore o uguale a Max" Foreground="#E40032" FontSize="11" Margin="0,4,0,0"
                                           Visibility="{Binding IsMinMaxValid, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            </StackPanel>

                            <!-- Formato -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Formato" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Format}" 
                                     Style="{StaticResource WatermarkTextBoxStyle}" Tag="Es: %.2f"
                                     Width="150" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                        </Grid>

                <!-- Descrizione e Stato — sempre editabili (anche in DictionaryContext/override mode) -->
                <Grid HorizontalAlignment="Left" Width="750">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Descrizione *" Foreground="White" VerticalAlignment="Top" Margin="0,8,0,12"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Descrizione della variabile"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80" Margin="0,0,0,12"
                             BorderBrush="{Binding IsDescriptionInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Stato" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding IsEnabled}" Content="Variabile attiva" 
                              Foreground="White" Margin="0,0,0,12"/>
                </Grid>
                    </StackPanel>
                </ScrollViewer>

        <!-- Errore -->
        <Border Grid.Row="2" Background="#E40032" Padding="10" Margin="0,0,0,16" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- Bottoni -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Command="{Binding CancelCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"/>
            <Button Content="💾 Salva" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"
                    Background="#004682" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
