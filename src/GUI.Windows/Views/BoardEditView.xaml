<UserControl x:Class="GUI.Windows.Views.BoardEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BoardEditViewModel}"
             Loaded="UserControl_Loaded"
             Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Compila i campi per creare o modificare una scheda." 
                   Foreground="#888888" FontSize="13" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Left" Width="500">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource WatermarkTextBoxStyle}" Tag="Nome scheda" MaxLength="100" Margin="0,0,0,12"
                         BorderBrush="{Binding IsNameInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Dispositivo" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DeviceDisplayName, Mode=OneWay}" 
                         IsEnabled="False" Padding="8,6" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Firmware Type *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,4"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding FirmwareType}" 
                             Style="{StaticResource WatermarkTextBoxStyle}" Tag="Es: 17, 20..."
                             Width="80" HorizontalAlignment="Left"
                             BorderBrush="{Binding IsFirmwareTypeInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>
                    <TextBlock Text="{Binding FirmwareTypeHint}" Foreground="#888888" FontSize="11"
                               Margin="0,3,0,0"
                               Visibility="{Binding FirmwareTypeHint, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Numero Scheda *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BoardNumber}" 
                         Style="{StaticResource WatermarkTextBoxStyle}" Tag="1..63"
                         Width="80" HorizontalAlignment="Left" Margin="0,0,0,12"
                         BorderBrush="{Binding IsBoardNumberInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Part Number" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PartNumber}" 
                         Style="{StaticResource WatermarkTextBoxStyle}" Tag="Es: DIS0020477"
                         MaxLength="50" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Principale" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>
                <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding IsPrimary}" 
                          Content="Scheda principale del dispositivo" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,12"/>
            </Grid>
        </ScrollViewer>

        <!-- Errore -->
        <Border Grid.Row="2" Background="#E40032" Padding="10" Margin="0,0,0,16" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- Bottoni -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="🗑️ Elimina scheda" Command="{Binding DeleteBoardCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="140"
                    Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
            <Button Content="Annulla" Command="{Binding CancelCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"/>
            <Button Content="💾 Salva" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"
                    Background="#004682" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
