<UserControl x:Class="GUI.Windows.Views.DeviceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             Background="#1E1E1E">
    <UserControl.Resources>
        <Style TargetType="Border" x:Key="DeviceCardStyle">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="BorderBrush" Value="#004682"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="&#x2795; New" Command="{Binding AddDeviceCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
            <Button Content="&#x1F504; Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Device list as a card grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceItem}">
                        <Border Style="{StaticResource DeviceCardStyle}" Margin="0,0,0,6"
                                HorizontalAlignment="Stretch"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding Tag.OpenDeviceCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="#FFFFFF"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Description}"
                                           FontSize="12" Foreground="#999999" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>

                                <!-- Counts on the right -->
                                <StackPanel Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <TextBlock Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Right">
                                        <Run Text="{Binding BoardCount, Mode=OneWay}"/>
                                        <Run Text=" boards"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Right" Margin="0,2,0,0">
                                        <Run Text="{Binding DictionaryCount, Mode=OneWay}"/>
                                        <Run Text=" dictionaries"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
