<UserControl x:Class="GUI.Windows.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Device header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <Button Content="✏️ Edit" Command="{Binding EditDeviceCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" DockPanel.Dock="Right"
                    VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Device:" FontSize="14" Foreground="#999999"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="1" Text="Loading..." FontSize="14" Foreground="#999999" Margin="0,0,0,10"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Error message -->
        <Border Grid.Row="2" Background="#E40032" Padding="10" Margin="0,0,0,10" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- ── DICTIONARIES ── -->
        <DockPanel Grid.Row="3">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Dictionaries" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="➕ New dictionary" Command="{Binding AddDictionaryCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Right"/>
            </DockPanel>
            <DataGrid ItemsSource="{Binding Dictionaries}"
                      SelectedItem="{Binding SelectedDictionary}"
                      Style="{StaticResource DarkDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                      CellStyle="{StaticResource DarkDataGridCellStyle}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenDictionaryCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dictionary" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Semantic}" Width="120" MinWidth="80"/>
                    <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="100" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ── BOARDS ── -->
        <DockPanel Grid.Row="4" Margin="0,15,0,0">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Boards" FontSize="13" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="➕ New" Command="{Binding AddBoardCommand}"
                        Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Right"/>
            </DockPanel>
        </DockPanel>

        <DataGrid Grid.Row="5" ItemsSource="{Binding Boards}"
                  SelectedItem="{Binding SelectedBoard}"
                  Style="{StaticResource DarkDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DarkDataGridRowStyle}"
                  CellStyle="{StaticResource DarkDataGridCellStyle}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick"
                              Command="{Binding EditBoardCommand}"
                              CommandParameter="{Binding SelectedBoard}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" MinWidth="100"/>
                <DataGridTextColumn Header="Machine Type" Binding="{Binding MachineCode}" Width="90" MinWidth="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="FW Type" Binding="{Binding FirmwareType}" Width="70" MinWidth="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="No." Binding="{Binding BoardNumber}" Width="50" MinWidth="40">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Header="Primary" Binding="{Binding IsPrimary}" Width="70" MinWidth="50"
                                        IsReadOnly="True" ElementStyle="{StaticResource DarkDataGridCheckBoxStyle}"/>
                <DataGridTextColumn Header="Dictionary" Binding="{Binding DictionaryName}" Width="150" MinWidth="80"/>
                <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="120" MinWidth="80"/>
                <DataGridTextColumn Header="Address" Binding="{Binding ProtocolAddress}" Width="110" MinWidth="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
