<UserControl x:Class="GUI.Windows.Views.DictionaryEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GUI.Windows.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DictionaryEditViewModel}"
             Loaded="UserControl_Loaded"
             Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition>
                <RowDefinition.Height>
                    <MultiBinding Converter="{StaticResource ExpandedRowHeightConverter}">
                        <Binding Path="ShowStandardSection"/>
                        <Binding Path="IsStandardExpanded"/>
                    </MultiBinding>
                </RowDefinition.Height>
            </RowDefinition>
            <RowDefinition>
                <RowDefinition.Height>
                    <MultiBinding Converter="{StaticResource ExpandedRowHeightConverter}">
                        <Binding Path="IsNew" Converter="{StaticResource InverseBoolConverter}"/>
                        <Binding Path="IsSpecificExpanded"/>
                    </MultiBinding>
                </RowDefinition.Height>
            </RowDefinition>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top section: dictionary form -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,10"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource WatermarkTextBoxStyle}" Tag="Dictionary name" MaxLength="100" Margin="0,0,0,10"
                     BorderBrush="{Binding IsNameInvalid, Converter={StaticResource BoolToErrorBrushConverter}}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" Foreground="White" VerticalAlignment="Top" Margin="0,8,0,10"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource WatermarkTextBoxStyle}" Tag="Optional description"
                     MaxLength="500" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Board *" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,10"
                       Visibility="{Binding ShowBoardSelector, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableBoards}" SelectedItem="{Binding SelectedBoard}"
                      DisplayMemberPath="Name" Padding="8,6" Margin="0,0,0,10"
                      Visibility="{Binding ShowBoardSelector, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Standard" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,10"
                       Visibility="{Binding CanSetStandard, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding IsStandard}"
                      Content="Common variables dictionary (0x00xx)" Foreground="White" Margin="0,0,0,10"
                      Visibility="{Binding CanSetStandard, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>

        <!-- Error -->
        <Border Grid.Row="1" Background="#E40032" Padding="10" Margin="0,0,0,10" CornerRadius="4"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- "Variables" header + toolbar (only for existing dictionaries) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4"
                    Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <TextBlock Text="Variables" Foreground="#CCCCCC" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="➕ New" Command="{Binding AddVariableCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
            <TextBox Text="{Binding VariableSearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}" Margin="8,0,0,0"/>
            <CheckBox IsChecked="{Binding ShowOnlyEnabled}" Content="Show only enabled"
                      Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Collapsible section: inherited standard variables (override IsEnabled + Description) -->
        <Expander Grid.Row="3" IsExpanded="{Binding IsStandardExpanded}" Margin="0,12,0,8"
                  Visibility="{Binding ShowStandardSection, Converter={StaticResource BoolToVisibilityConverter}}">
            <Expander.Header>
                <TextBlock Text="📋 Inherited standard variables" Foreground="#AAAAAA" FontSize="13" FontWeight="SemiBold"/>
            </Expander.Header>
            <DataGrid ItemsSource="{Binding StandardVariables}" SelectedItem="{Binding SelectedStandardVariable}"
                      IsReadOnly="True"
                      Margin="0,8,0,0"
                      Style="{StaticResource DarkDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                      CellStyle="{StaticResource DarkDataGridCellStyle}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditStandardVariableCommand}"
                                  CommandParameter="{Binding SelectedStandardVariable}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" MinWidth="100"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="90" MinWidth="70"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="110" MinWidth="80"/>
                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="60" MinWidth="50"
                                            ElementStyle="{StaticResource DarkDataGridCheckBoxStyle}"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <!-- Collapsible section: dictionary-specific variables (0x80xx) -->
        <Expander Grid.Row="4" IsExpanded="{Binding IsSpecificExpanded}" Margin="0,4,0,4"
                  Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <Expander.Header>
                <TextBlock Text="📝 Specific variables" Foreground="#AAAAAA" FontSize="13" FontWeight="SemiBold"/>
            </Expander.Header>
            <DataGrid ItemsSource="{Binding Variables}" SelectedItem="{Binding SelectedVariable}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      Margin="0,8,0,0"
                      Style="{StaticResource DarkDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DarkDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DarkDataGridRowStyle}"
                      CellStyle="{StaticResource DarkDataGridCellStyle}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditVariableCommand}" CommandParameter="{Binding SelectedVariable}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" MinWidth="100"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="90" MinWidth="70"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="110" MinWidth="80"/>
                    <DataGridTextColumn Header="Access" Binding="{Binding AccessMode}" Width="90" MinWidth="70"/>
                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="60" MinWidth="50" IsReadOnly="True"
                                            ElementStyle="{StaticResource DarkDataGridCheckBoxStyle}"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="🗑️ Delete dictionary" Command="{Binding DeleteDictionaryCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="140"
                    Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"/>
            <Button Content="💾 Save" Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" MinWidth="100"
                    Background="#004682" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="6" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
