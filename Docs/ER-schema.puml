@startuml database-schema
' =============================================================================
' Stem.Dictionaries.Manager - Database Schema (Domain v7)
' Aggiornato: SESSION_040 (2026-04-07)
' =============================================================================

!define TABLE(name) entity name << (T,#FFAAAA) >>
!define PK(field) <b>field</b>
!define FK(field) <i>field</i>

skinparam linetype ortho
skinparam entity {
    BackgroundColor #F5F5F5
    BorderColor #333333
}

' === UTENTI E AUDIT ===

TABLE(Users) {
    PK(Id) : int
    --
    Username : string(50) <<unique>>
    DisplayName : string(100)
    CreatedAt : datetime
    UpdatedAt : datetime?
}

TABLE(AuditEntries) {
    PK(Id) : int
    --
    EntityType : int (AuditEntityType enum)
    EntityId : int
    Operation : int (AuditOperation enum)
    FK(ChangedById) : int → Users
    ChangedAt : datetime
    PreviousValue : text?
    NewValue : text?
    Notes : string(500)?
}

Users ||--o{ AuditEntries : "ChangedById"

' === DISPOSITIVI ===

TABLE(Devices) {
    PK(Id) : int
    --
    Name : string(50) <<unique>>
    Description : string(500)?
    MachineCode : int
    CreatedAt : datetime
    UpdatedAt : datetime?
}

' === SCHEDE ===

TABLE(Boards) {
    PK(Id) : int
    --
    FK(DeviceId) : int → Devices
    Name : string(50)
    FirmwareType : int
    BoardNumber : int
    PartNumber : string(20)?
    ProtocolAddress : uint <<unique>>
    IsPrimary : bool
    FK(DictionaryId) : int? → Dictionaries
    CreatedAt : datetime
    UpdatedAt : datetime?
}

Devices ||--o{ Boards : "DeviceId"

' === DIZIONARI E VARIABILI ===

TABLE(Dictionaries) {
    PK(Id) : int
    --
    Name : string(50) <<unique>>
    Description : string(500)?
    IsStandard : bool
    CreatedAt : datetime
    UpdatedAt : datetime?
}

TABLE(Variables) {
    PK(Id) : int
    --
    FK(DictionaryId) : int → Dictionaries
    Name : string(100)
    AddressHigh : byte
    AddressLow : byte
    DataTypeKind : int (enum)
    DataTypeParam : int?
    DataTypeRaw : string(50)
    Format : string(50)?
    MinValue : double?
    MaxValue : double?
    Unit : string(20)?
    AccessMode : int (enum)
    Usage : string(200)?
    Description : string(2000)?
    IsEnabled : bool
    WordSize : int? (8, 16, 32)
    CreatedAt : datetime
    UpdatedAt : datetime?
}

TABLE(BitInterpretations) {
    PK(Id) : int
    --
    FK(VariableId) : int → Variables
    FK(DictionaryId) : int? → Dictionaries
    WordIndex : int
    BitIndex : int
    Meaning : string(200)?
    CreatedAt : datetime
    UpdatedAt : datetime?
}

Dictionaries ||--o{ Variables : "DictionaryId"
Dictionaries ||--o{ Boards : "DictionaryId"
Variables ||--o{ BitInterpretations : "VariableId"
Dictionaries ||--o{ BitInterpretations : "DictionaryId"

' === COMANDI ===

TABLE(Commands) {
    PK(Id) : int
    --
    Name : string(100) <<unique>>
    CodeHigh : byte
    CodeLow : byte
    IsResponse : bool
    ParametersJson : string(1000)
    CreatedAt : datetime
    UpdatedAt : datetime?
}

TABLE(CommandDeviceStates) {
    PK(Id) : int
    --
    FK(CommandId) : int → Commands
    FK(DeviceId) : int → Devices
    IsEnabled : bool
    CreatedAt : datetime
    UpdatedAt : datetime?
}

Commands ||--o{ CommandDeviceStates : "CommandId"
Devices ||--o{ CommandDeviceStates : "DeviceId"

' === OVERRIDE VARIABILI STANDARD PER-DIZIONARIO (v7) ===

TABLE(StandardVariableOverrides) {
    PK(Id) : int
    --
    FK(DictionaryId) : int → Dictionaries
    FK(StandardVariableId) : int → Variables
    IsEnabled : bool
    Description : string(2000)?
    CreatedAt : datetime
    UpdatedAt : datetime?
}

Dictionaries ||--o{ StandardVariableOverrides : "DictionaryId"
Variables ||--o{ StandardVariableOverrides : "StandardVariableId"

' === NOTE ===

note bottom of Variables
  **Unique constraint:**
  (DictionaryId, AddressHigh, AddressLow)

  **Category derivata:**
  AddressHigh = 0x00 → Standard
  AddressHigh = 0x80 → DeviceSpecific

  **WordSize (BR-019):**
  Solo per Bitmapped: 8, 16 o 32
end note

note bottom of BitInterpretations
  **Unique constraint (BR-017):**
  (VariableId, DictionaryId, WordIndex, BitIndex)
  2 partial indexes (NULL / NOT NULL)

  DictionaryId = NULL → template
  DictionaryId = N → per-dizionario
  **BR-018:** per-dizionario > template
end note

note bottom of Commands
  **Unique constraint:**
  (CodeHigh, CodeLow, IsResponse)

  Name è anche unique
end note

note bottom of CommandDeviceStates
  **Unique constraint:**
  (CommandId, DeviceId)
end note

note bottom of StandardVariableOverrides
  **Unique constraint (BR-010):**
  (DictionaryId, StandardVariableId)

  Override per-dizionario di una
  variabile standard (0x00xx).
  **BR-009:** stato effettivo
  **BR-011:** coerenza IsEnabled
  **BR-020:** descrizione effettiva
end note

note bottom of Dictionaries
  IsStandard = true → dizionario
  delle variabili comuni 0x00xx.
  Max 1 nel sistema (BR-004).

  Non-standard **eredita** tutte
  le variabili standard (v7).
  Override via StandardVariableOverrides.

  **Semantica derivata (runtime):**
  · Dedicated: 1 solo Device
  · Shared: 2+ Device diversi
  · Orphan: nessun Board associato
end note

note bottom of Boards
  **BR-005:** Max 1 IsPrimary=true
  per Device (partial unique index)

  DictionaryId = NULL →
  board senza dizionario proprio
end note

note bottom of Devices
  **BR-014:** MachineCode > 0
  **BR-015:** MachineCode ≠ 6 (BLE)
end note

@enduml
